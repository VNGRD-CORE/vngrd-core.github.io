# ── DRIS//CORE Transcription Backend — Environment Config ──────────────────
# Copy to .env and fill in your values. NEVER commit .env to version control.

# OpenAI key — needed for both Whisper (transcription) and GPT-4o (translation)
OPENAI_API_KEY=sk-...

# Source language hint for Whisper (ISO-639-1). Defaults to "en".
SOURCE_LANG=en

# Optional: fix a specific PyAudio device index (run /devices to list them)
# MIC_DEVICE_INDEX=0
